generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id          String @id @default(uuid())
  title       String
  location    String
  description String

  price        Int
  pricePerSqft Int?
  priceNote    String?
  callForPrice Boolean @default(false)
  isSoldOut    Boolean @default(false)

  bedrooms      Int?
  bathrooms     Int?
  halfBaths     Int?
  totalRooms    Int?
  floors        Int?
  floorLevel    Int?
  areaSqft      Int?
  lotSizeSqft   Int?
  yearBuilt     Int?
  yearRemodeled Int?

  rentPeriods     String[] @default([])
  statuses        String[] @default([])
  parkingOptions  String[] @default([])
  basementOptions String[] @default([])

  type            PropertyType    @default(RENT)
  subType         SubType         @default(FLAT)
  layoutType      LayoutType      @default(BHK1)
  furnishing      Furnishing      @default(FURNISHED)
  amenityCategory AmenityCategory @default(BASIC)

  images         PropertyImage[]
  basicAmenities BasicAmenity[]
  fullAmenities  FullAmenity[]
  cartItems      CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  createdAt  DateTime @default(now())
}

model BasicAmenity {
  id         String   @id @default(uuid())
  name       String
  normalized String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  createdAt  DateTime @default(now())

  @@unique([propertyId, normalized])
}

model FullAmenity {
  id         String   @id @default(uuid())
  name       String
  normalized String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  createdAt  DateTime @default(now())

  @@unique([propertyId, normalized])
}

// ── User (for future auth) ───────────────────────────────────────────────────
model User {
  id        String    @id @default(uuid())
  name      String?
  email     String    @unique
  phone     String?
  password  String? // hashed, optional — for email/password auth later
  cart      Cart?
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ── Cart (one per user) ───────────────────────────────────────────────────────
model Cart {
  id        String     @id @default(uuid())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String     @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id         String   @id @default(uuid())
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId     String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  addedAt    DateTime @default(now())

  @@unique([cartId, propertyId])
}

// ── Booking ───────────────────────────────────────────────────────────────────
model Booking {
  id            String   @id @default(uuid())
  name          String
  email         String
  phone         String
  date          String
  time          String
  propertyTitle String
  propertyId    String
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  createdAt     DateTime @default(now())
}

enum AmenityCategory {
  BASIC
  FULL
}

enum PropertyType {
  RENT
  LEASE
  SALE
}

enum SubType {
  FLAT
  STANDALONE_HOUSE
  INDEPENDENT_VILLA
  PENTHOUSE
}

enum LayoutType {
  BHK1   @map("1BHK")
  BHK2   @map("2BHK")
  BHK2_5 @map("2_5BHK")
  BHK3   @map("3BHK")
  BHK3_5 @map("3_5BHK")
  BHK4   @map("4BHK")
  BHK5   @map("5BHK")
  BHK5P  @map("5BHKP")
}

enum Furnishing {
  FURNISHED
  SEMIFURNISHED
  UNFURNISHED
}
