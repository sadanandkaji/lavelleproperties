generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id              String          @id @default(uuid())
  title           String
  location        String
  description     String

  // Pricing
  price           Int
  pricePerSqft    Int?
  priceNote       String?
  callForPrice    Boolean         @default(false)

  // Basic Facts
  bedrooms        Int?
  bathrooms       Int?
  halfBaths       Int?
  totalRooms      Int?
  floors          Int?
  floorLevel      Int?
  areaSqft        Int?
  lotSizeSqft     Int?
  yearBuilt       Int?
  yearRemodeled   Int?

  // Tags (stored as string arrays)
  rentPeriods     String[]        @default([])
  statuses        String[]        @default([])
  parkingOptions  String[]        @default([])
  basementOptions String[]        @default([])

  // Categorization
  type            PropertyType    @default(RENT)
  subType         SubType         @default(FLAT)
  layoutType      LayoutType      @default(BHK1)
  furnishing      Furnishing      @default(FURNISHED)
  amenityCategory AmenityCategory @default(BASIC)

  // Images — up to 10, stored as related records
  images          PropertyImage[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  createdAt  DateTime @default(now())
}

model Amenity {
  id       String          @id @default(uuid())
  name     String          @unique
  category AmenityCategory @default(BASIC)
}

enum AmenityCategory {
  BASIC
  FULL
}

enum PropertyType {
  RENT
  LEASE
  SALE
}

enum SubType {
  FLAT
  STANDALONE_HOUSE
  INDEPENDENT_VILLA
  PENTHOUSE
}

enum LayoutType {
  BHK1   @map("1BHK")
  BHK2   @map("2BHK")
  BHK2_5 @map("2_5BHK")
  BHK3   @map("3BHK")
  BHK3_5 @map("3_5BHK")
  BHK4   @map("4BHK")
  BHK5   @map("5BHK")
  BHK5P  @map("5BHKP")
}

enum Furnishing {
  FURNISHED
  SEMIFURNISHED
  UNFURNISHED
}
